# Frontend: set this to your deployed WhatsApp API base URL in production.
VITE_WHATSAPP_API_BASE_URL=http://localhost:8787

# Cloudinary unsigned upload settings for student/member photos.
VITE_CLOUDINARY_CLOUD_NAME=replace_with_cloudinary_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=replace_with_unsigned_upload_preset
VITE_CLOUDINARY_UPLOAD_FOLDER=sumjay/students

# WhatsApp API server.
WHATSAPP_API_PORT=8787
WHATSAPP_ACCESS_TOKEN=replace_with_meta_whatsapp_cloud_api_token
WHATSAPP_PHONE_NUMBER_ID=replace_with_meta_phone_number_id
WHATSAPP_API_VERSION=v23.0
WHATSAPP_TEMPLATE_LANGUAGE=en_US

# Comma-separated frontend origins allowed to call the WhatsApp API.
# Production example: https://your-app.web.app,https://your-custom-domain.com
WHATSAPP_ALLOWED_ORIGIN=http://localhost:3000

# Used only when a recipient is entered as a local 10-digit number.
# International recipients should be stored with +country code, e.g. +971501234567.
WHATSAPP_DEFAULT_COUNTRY_CODE=91

# Template names currently used by the app:
# absence_notification body variables: student name, date
# receipt_student body variables: month, student name
# membership_receipt body variables: fund type, month/year, member name
# warning body variables: recipient label, name, payment/fund detail, month/year
