rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Primitive Helpers
    function isSignedIn() { return request.auth != null; }
    function isAdmin(adminId) { return isSignedIn() && request.auth.uid == adminId; }
    function isValidId(id) { return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Student Entity Validation
    function isValidStudent(data) {
      return data.keys().hasAll(['adminId', 'name', 'dob', 'place', 'parentMobile', 'createdAt'])
        && data.adminId is string && data.adminId == request.auth.uid
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.dob is string && data.dob.size() == 10 && data.dob.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$')
        && data.place is string && data.place.size() <= 200
        && data.parentMobile is string && data.parentMobile.size() <= 20
        && data.createdAt is number
        && (data.keys().hasAll(['photoURL']) ? (data.photoURL is string && data.photoURL.size() <= 500) : true)
        && (data.keys().hasAll(['updatedAt']) ? data.updatedAt is number : true);
    }

    // Attendance Entity Validation
    function isValidAttendance(data) {
      return data.keys().hasAll(['adminId', 'studentId', 'date', 'status', 'createdAt'])
        && data.adminId is string && data.adminId == request.auth.uid
        && data.studentId is string && data.studentId.size() > 0 && data.studentId.size() <= 128
        && data.date is string && data.date.size() == 10 && data.date.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$')
        && data.status is string && (data.status == 'present' || data.status == 'absent')
        && data.createdAt is number
        && (data.keys().hasAll(['updatedAt']) ? data.updatedAt is number : true);
    }

    // Fee Entity Validation
    function isValidFee(data) {
      return data.keys().hasAll(['adminId', 'studentId', 'month', 'status', 'createdAt'])
        && data.adminId is string && data.adminId == request.auth.uid
        && data.studentId is string && data.studentId.size() > 0 && data.studentId.size() <= 128
        && data.month is string && data.month.size() == 7 && data.month.matches('^[0-9]{4}-[0-9]{2}$')
        && data.status is string && (data.status == 'paid' || data.status == 'unpaid')
        && data.createdAt is number
        && (data.keys().hasAll(['updatedAt']) ? data.updatedAt is number : true);
    }

    // /students/{studentId}
    match /students/{studentId} {
      allow get: if isValidId(studentId) && isAdmin(existing().adminId);
      allow list: if isSignedIn() && existing().adminId == request.auth.uid;
      allow create: if isValidId(studentId) 
                    && isValidStudent(incoming());
      allow update: if isValidId(studentId)
                    && isAdmin(existing().adminId)
                    && isValidStudent(incoming())
                    && incoming().adminId == existing().adminId
                    && incoming().createdAt == existing().createdAt;
      allow delete: if isValidId(studentId) && isAdmin(existing().adminId);
    }

    // /attendance/{recordId}
    match /attendance/{recordId} {
      allow get: if isValidId(recordId) && isAdmin(existing().adminId);
      allow list: if isSignedIn() && existing().adminId == request.auth.uid;
      allow create: if isValidId(recordId) 
                    && isValidAttendance(incoming()) 
                    // Relation check: ensure student exists and is owned by admin
                    && get(/databases/$(database)/documents/students/$(incoming().studentId)).data.adminId == request.auth.uid;
      allow update: if isValidId(recordId)
                    && isAdmin(existing().adminId)
                    && isValidAttendance(incoming())
                    && incoming().adminId == existing().adminId
                    && incoming().studentId == existing().studentId
                    && incoming().createdAt == existing().createdAt;
      allow delete: if isValidId(recordId) && isAdmin(existing().adminId);
    }

    // /fees/{feeId}
    match /fees/{feeId} {
      allow get: if isValidId(feeId) && isAdmin(existing().adminId);
      allow list: if isSignedIn() && existing().adminId == request.auth.uid;
      allow create: if isValidId(feeId) 
                    && isValidFee(incoming()) 
                    && get(/databases/$(database)/documents/students/$(incoming().studentId)).data.adminId == request.auth.uid;
      allow update: if isValidId(feeId)
                    && isAdmin(existing().adminId)
                    && isValidFee(incoming())
                    && incoming().adminId == existing().adminId
                    && incoming().studentId == existing().studentId
                    && incoming().createdAt == existing().createdAt;
      allow delete: if isValidId(feeId) && isAdmin(existing().adminId);
    }
  }
}
