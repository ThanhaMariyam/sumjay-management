rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Primitive Helpers
    function isSignedIn() { return request.auth != null; }
    function isAdmin(adminId) { return isSignedIn() && request.auth.uid == adminId; }
    function isMembershipAdmin() {
      return isSignedIn() && request.auth.token.email == 'membership_admin@sumjay.club';
    }
    function isValidId(id) { return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Student Entity Validation
    function isValidStudent(data) {
      return data.keys().hasAll(['adminId', 'name', 'dob', 'place', 'parentMobile', 'createdAt'])
        && data.adminId is string && data.adminId == request.auth.uid
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.dob is string && data.dob.size() == 10 && data.dob.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$')
        && data.place is string && data.place.size() <= 200
        && data.parentMobile is string && data.parentMobile.size() <= 20
        && data.createdAt is number
        && (data.keys().hasAll(['photoURL']) ? (data.photoURL is string && data.photoURL.size() <= 1000) : true)
        && (data.keys().hasAll(['updatedAt']) ? data.updatedAt is number : true);
    }

    // Member Entity Validation
    function isValidMember(data) {
      return data.keys().hasAll(['adminId', 'name', 'dob', 'place', 'phoneNumber', 'bloodGroup', 'createdAt'])
        && data.adminId is string && data.adminId.size() > 0 && data.adminId.size() <= 128
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.dob is string && data.dob.size() == 10 && data.dob.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$')
        && data.place is string && data.place.size() <= 200
        && data.phoneNumber is string && data.phoneNumber.size() <= 20
        && data.bloodGroup is string && data.bloodGroup.size() > 0 && data.bloodGroup.size() <= 10
        && data.createdAt is number
        && (data.keys().hasAll(['userId']) ? (data.userId is string && data.userId.size() > 0 && data.userId.size() <= 128) : true)
        && (data.keys().hasAll(['email']) ? (data.email is string && data.email.size() <= 200) : true)
        && (data.keys().hasAll(['photoURL']) ? (data.photoURL is string && data.photoURL.size() <= 1000) : true)
        && (data.keys().hasAll(['updatedAt']) ? data.updatedAt is number : true);
    }

    // Attendance Entity Validation
    function isValidAttendance(data) {
      return data.keys().hasAll(['adminId', 'studentId', 'date', 'status', 'createdAt'])
        && data.adminId is string && data.adminId == request.auth.uid
        && data.studentId is string && data.studentId.size() > 0 && data.studentId.size() <= 128
        && data.date is string && data.date.size() == 10 && data.date.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$')
        && data.status is string && (data.status == 'present' || data.status == 'absent')
        && data.createdAt is number
        && (data.keys().hasAll(['updatedAt']) ? data.updatedAt is number : true);
    }

    // Fee Entity Validation
    function isValidFee(data) {
      return data.keys().hasAll(['adminId', 'studentId', 'month', 'status', 'createdAt'])
        && data.adminId is string && data.adminId.size() > 0 && data.adminId.size() <= 128
        && data.studentId is string && data.studentId.size() > 0 && data.studentId.size() <= 128
        && data.month is string && data.month.size() == 7 && data.month.matches('^[0-9]{4}-[0-9]{2}$')
        && data.status is string && (data.status == 'paid' || data.status == 'unpaid')
        && data.createdAt is number
        && (data.keys().hasAll(['updatedAt']) ? data.updatedAt is number : true);
    }

    // WhatsApp Sent Message Validation
    function isValidWhatsAppMessage(data) {
      return data.keys().hasAll(['adminId', 'sendKey', 'category', 'targetId', 'messageType', 'periodKey', 'sentAt'])
        && data.adminId is string && data.adminId == request.auth.uid
        && data.sendKey is string && data.sendKey.size() > 0 && data.sendKey.size() <= 500
        && data.category is string && (data.category == 'fee' || data.category == 'attendance')
        && data.targetId is string && data.targetId.size() > 0 && data.targetId.size() <= 128
        && data.messageType is string && data.messageType.size() > 0 && data.messageType.size() <= 32
        && data.periodKey is string && data.periodKey.size() >= 7 && data.periodKey.size() <= 10
        && data.sentAt is number;
    }

    // /students/{studentId}
    match /students/{studentId} {
      allow get: if isValidId(studentId) && isAdmin(existing().adminId);
      allow list: if isSignedIn() && existing().adminId == request.auth.uid;
      allow create: if isValidId(studentId) 
                    && isValidStudent(incoming());
      allow update: if isValidId(studentId)
                    && isAdmin(existing().adminId)
                    && isValidStudent(incoming())
                    && incoming().adminId == existing().adminId
                    && incoming().createdAt == existing().createdAt;
      allow delete: if isValidId(studentId) && isAdmin(existing().adminId);
    }

    // /members/{memberId}
    match /members/{memberId} {
      allow get: if isValidId(memberId)
                 && (isSignedIn()
                     || isMembershipAdmin()
                     || isAdmin(existing().adminId)
                     || (existing().keys().hasAll(['userId']) && existing().userId == request.auth.uid));
      allow list: if isSignedIn()
                  && (isMembershipAdmin()
                      || isSignedIn()
                      || existing().adminId == request.auth.uid
                      || (
                        request.auth.token.email is string
                        && existing().keys().hasAll(['email'])
                        && existing().email == request.auth.token.email
                      )
                      || (existing().keys().hasAll(['userId']) && existing().userId == request.auth.uid));
      allow create: if isValidId(memberId)
                    && isValidMember(incoming())
                    && incoming().adminId == request.auth.uid;
      allow update: if isValidId(memberId)
                    && (isMembershipAdmin()
                        || isAdmin(existing().adminId)
                        || (existing().keys().hasAll(['userId']) && existing().userId == request.auth.uid)
                        || (
                          !existing().keys().hasAll(['userId'])
                          && request.auth.token.email is string
                          && existing().keys().hasAll(['email'])
                          && existing().email == request.auth.token.email
                          && incoming().userId == request.auth.uid
                        ))
                    && isValidMember(incoming())
                    && incoming().adminId == existing().adminId
                    && incoming().createdAt == existing().createdAt
                    && (!existing().keys().hasAll(['userId']) || incoming().userId == existing().userId);
      allow delete: if isValidId(memberId) && (isMembershipAdmin() || isAdmin(existing().adminId));
    }

    // /attendance/{recordId}
    match /attendance/{recordId} {
      allow get: if isValidId(recordId) && isAdmin(existing().adminId);
      allow list: if isSignedIn() && existing().adminId == request.auth.uid;
      allow create: if isValidId(recordId) 
                    && isValidAttendance(incoming()) 
                    // Relation check: ensure student exists and is owned by admin
                    && get(/databases/$(database)/documents/students/$(incoming().studentId)).data.adminId == request.auth.uid;
      allow update: if isValidId(recordId)
                    && isAdmin(existing().adminId)
                    && isValidAttendance(incoming())
                    && incoming().adminId == existing().adminId
                    && incoming().studentId == existing().studentId
                    && incoming().createdAt == existing().createdAt;
      allow delete: if isValidId(recordId) && isAdmin(existing().adminId);
    }

    // /fees/{feeId}
    match /fees/{feeId} {
      allow get: if isValidId(feeId)
                 && (isAdmin(existing().adminId)
                     || isMembershipAdmin()
                     || (
                       exists(/databases/$(database)/documents/members/$(existing().studentId))
                       && get(/databases/$(database)/documents/members/$(existing().studentId)).data.userId == request.auth.uid
                     ));
      allow list: if isSignedIn()
                  && (isSignedIn()
                      || existing().adminId == request.auth.uid
                      || isMembershipAdmin()
                      || (
                        exists(/databases/$(database)/documents/members/$(existing().studentId))
                        && get(/databases/$(database)/documents/members/$(existing().studentId)).data.userId == request.auth.uid
                      ));
      allow create: if isValidId(feeId) 
                    && isValidFee(incoming()) 
                    && (incoming().adminId == request.auth.uid || isMembershipAdmin())
                    && (
                      get(/databases/$(database)/documents/students/$(incoming().studentId)).data.adminId == request.auth.uid
                      || get(/databases/$(database)/documents/members/$(incoming().studentId)).data.adminId == request.auth.uid
                      || (isMembershipAdmin() && exists(/databases/$(database)/documents/members/$(incoming().studentId)))
                    );
      allow update: if isValidId(feeId)
                    && (isAdmin(existing().adminId) || isMembershipAdmin())
                    && isValidFee(incoming())
                    && incoming().adminId == existing().adminId
                    && incoming().studentId == existing().studentId
                    && incoming().createdAt == existing().createdAt;
      allow delete: if isValidId(feeId) && (isAdmin(existing().adminId) || isMembershipAdmin());
    }

    // /whatsappMessages/{messageId}
    match /whatsappMessages/{messageId} {
      allow get: if isValidId(messageId) && isAdmin(existing().adminId);
      allow list: if isSignedIn() && existing().adminId == request.auth.uid;
      allow create: if isValidId(messageId)
                    && isValidWhatsAppMessage(incoming())
                    && incoming().sendKey == messageId;
      allow update: if isValidId(messageId)
                    && isAdmin(existing().adminId)
                    && isValidWhatsAppMessage(incoming())
                    && incoming().adminId == existing().adminId
                    && incoming().sendKey == existing().sendKey
                    && incoming().targetId == existing().targetId
                    && incoming().category == existing().category
                    && incoming().messageType == existing().messageType
                    && incoming().periodKey == existing().periodKey;
      allow delete: if false;
    }
  }
}
